{
  "permissions": {
    "allow": [
      "Bash(npm run lint)",
      "Bash(npm run test)",
      "Bash(npm run build)",
      "Bash(npm run type-check)",
      "Bash(npm run dev)",
      "Bash(npm install)",
      "Bash(npx vitest run:*)",
      "Bash(node --test:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/protect-harness.py\""
          }
        ]
      }
    ]
  }
}
